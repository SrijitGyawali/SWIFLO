NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# Remittance pool program — defaults to the deployed devnet address
NEXT_PUBLIC_REMITTANCE_POOL_PROGRAM_ID=GKWPTDkKS2jDrE3gkWWoTtbHnwaiqZwc8iM47QGsJ9mJ
# Pool's USDC token account (created during pool initialization — not an ATA)
NEXT_PUBLIC_POOL_USDC=your_pool_usdc_token_account
# USDC mint — defaults to Circle devnet USDC if not set
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
