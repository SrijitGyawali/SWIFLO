# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_API_KEY=your_helius_api_key
ANCHOR_WALLET=~/.config/solana/id.json

# Program IDs (fill in after first deploy)
REMITTANCE_POOL_PROGRAM_ID=
LIQUIDITY_VAULT_PROGRAM_ID=
RATE_ORACLE_PROGRAM_ID=

# Backend API
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swiflo
MTO_MOCK_URL=http://localhost:3002
WEBHOOK_SECRET=change_me_in_production

# MTO Mock
MTO_PORT=3002
MTO_SIGNING_KEYPAIR_PATH=./keys/mto-signer.json

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
